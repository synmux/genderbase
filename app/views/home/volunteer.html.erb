<section class="hero min-h-[40vh] bg-gradient-to-br from-secondary/10 to-base-200 rounded-xl mb-10 flex items-center justify-center shadow-lg">
  <div class="text-center">
    <div class="flex justify-center mb-4">
      <div class="bg-secondary/20 rounded-full p-4 inline-block">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 01-8 0M12 11v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    </div>
    <h1 class="text-4xl font-extrabold text-secondary mb-2">Volunteer with Genderbase</h1>
    <p class="text-lg text-base-content/70 max-w-2xl mx-auto">Join our community of dedicated volunteers helping to make gender information accessible, accurate, and supportive for everyone.</p>
  </div>
</section>

<div class="container mx-auto px-4 py-8 max-w-6xl">
  <div class="prose lg:prose-xl max-w-none">
    <div class="divider my-8 before:bg-secondary/20 after:bg-secondary/20">Volunteer Roles</div>
    <p class="mb-8">Genderbase relies on volunteers with diverse backgrounds, experiences, and skills to create a platform that truly serves our community. Whether you have a few hours a week or can contribute occasionally, your help is valuable to us.</p>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
    <!-- Volunteer Role 1 -->
    <div class="bg-base-200 rounded-xl p-6 flex flex-col shadow">
      <span class="badge badge-secondary badge-outline mb-2 whitespace-nowrap text-sm">Content Creator</span>
      <p class="mb-4">Help develop educational articles, resources, and responses for our knowledge base and Q&A platform.</p>
      <ul class="list-disc pl-6 mb-6">
        <li class="mb-2">Research and write articles on gender-related topics</li>
        <li class="mb-2">Review and edit content for accuracy and clarity</li>
        <li class="mb-2">Help develop terminology definitions</li>
      </ul>
      <span class="badge badge-ghost mb-2 whitespace-nowrap text-xs">2-5 hrs/week</span>
      <span class="badge badge-ghost mb-4 whitespace-nowrap text-xs">Research, writing, detail</span>
    </div>
    <!-- Volunteer Role 2 -->
    <div class="bg-base-200 rounded-xl p-6 flex flex-col shadow">
      <span class="badge badge-secondary badge-outline mb-2 whitespace-nowrap text-sm">Community Responder</span>
      <p class="mb-4">Answer questions from our community with compassion, accuracy, and support.</p>
      <ul class="list-disc pl-6 mb-6">
        <li class="mb-2">Respond to submitted questions</li>
        <li class="mb-2">Provide supportive, informative answers</li>
        <li class="mb-2">Direct users to additional resources when appropriate</li>
      </ul>
      <span class="badge badge-ghost mb-2 whitespace-nowrap text-xs">3-6 hrs/week</span>
      <span class="badge badge-ghost mb-4 whitespace-nowrap text-xs">Communication, empathy, knowledge</span>
    </div>
    <!-- Volunteer Role 3 -->
    <div class="bg-base-200 rounded-xl p-6 flex flex-col shadow">
      <span class="badge badge-secondary badge-outline mb-2 whitespace-nowrap text-sm">Technical Contributor</span>
      <p class="mb-4">Help build and maintain our platform with your coding and design skills.</p>
      <ul class="list-disc pl-6 mb-6">
        <li class="mb-2">Contribute to our open-source codebase</li>
        <li class="mb-2">Improve accessibility and user experience</li>
        <li class="mb-2">Fix bugs and implement new features</li>
      </ul>
      <span class="badge badge-ghost mb-2 whitespace-nowrap text-xs">Flexible</span>
      <span class="badge badge-ghost mb-4 whitespace-nowrap text-xs">Programming, web, design</span>
    </div>
    <!-- Volunteer Role 4 -->
    <div class="bg-base-200 rounded-xl p-6 flex flex-col shadow">
      <span class="badge badge-secondary badge-outline mb-2 whitespace-nowrap text-sm">Resource Curator</span>
      <p class="mb-4">Help identify, evaluate, and organize external resources for our community.</p>
      <ul class="list-disc pl-6 mb-6">
        <li class="mb-2">Research reputable organizations and resources</li>
        <li class="mb-2">Evaluate resources for inclusion in our database</li>
        <li class="mb-2">Organize and categorize resources</li>
      </ul>
      <span class="badge badge-ghost mb-2 whitespace-nowrap text-xs">2-4 hrs/week</span>
      <span class="badge badge-ghost mb-4 whitespace-nowrap text-xs">Research, organization, critical thinking</span>
    </div>
    <!-- Volunteer Role 5 -->
    <div class="bg-base-200 rounded-xl p-6 flex flex-col shadow">
      <span class="badge badge-secondary badge-outline mb-2 whitespace-nowrap text-sm">Community Moderator</span>
      <p class="mb-4">Help maintain a safe, supportive environment for all users.</p>
      <ul class="list-disc pl-6 mb-6">
        <li class="mb-2">Review user-submitted content</li>
        <li class="mb-2">Enforce community guidelines</li>
        <li class="mb-2">Support users who report issues</li>
      </ul>
      <span class="badge badge-ghost mb-2 whitespace-nowrap text-xs">3-5 hrs/week</span>
      <span class="badge badge-ghost mb-4 whitespace-nowrap text-xs">Judgment, conflict resolution, empathy</span>
    </div>
    <!-- Volunteer Role 6 -->
    <div class="bg-base-200 rounded-xl p-6 flex flex-col shadow">
      <span class="badge badge-secondary badge-outline mb-2 whitespace-nowrap text-sm">Translator</span>
      <p class="mb-4">Help make our resources accessible in multiple languages.</p>
      <ul class="list-disc pl-6 mb-6">
        <li class="mb-2">Translate articles and resources</li>
        <li class="mb-2">Review translations for accuracy</li>
        <li class="mb-2">Help develop language-specific terminology guides</li>
      </ul>
      <span class="badge badge-ghost mb-2 whitespace-nowrap text-xs">Flexible</span>
      <span class="badge badge-ghost mb-4 whitespace-nowrap text-xs">Fluency, cultural competence</span>
    </div>
  </div>

  <div class="prose lg:prose-xl max-w-none">
    <div class="divider my-8 before:bg-secondary/20 after:bg-secondary/20">How to Apply</div>
    <p class="mb-6">Interested in volunteering with us? We'd love to have you join our team! Here's how to get started:</p>
  </div>
  <div class="bg-base-200 rounded-xl p-8 md:p-10 mb-12 shadow">
    <ol class="list-decimal pl-6 mb-8">
      <li class="mb-4">
        <strong>Complete our volunteer application form</strong>
        <p class="mt-2">Tell us about yourself, your interests, and how you'd like to contribute.</p>
      </li>
      <li class="mb-4">
        <strong>Attend an orientation session</strong>
        <p class="mt-2">Learn about our mission, values, and volunteer guidelines.</p>
      </li>
      <li class="mb-4">
        <strong>Complete role-specific training</strong>
        <p class="mt-2">Depending on your role, you'll receive training to help you succeed.</p>
      </li>
      <li class="mb-4">
        <strong>Join our volunteer community</strong>
        <p class="mt-2">Connect with other volunteers and start making a difference!</p>
      </li>
    </ol>
    <div class="text-center">
      <a href="#" class="btn btn-primary btn-lg !py-4">Apply to Volunteer</a>
    </div>
  </div>

  <div class="mt-12 text-center">
    <h2 class="text-2xl font-bold mb-4">Questions About Volunteering?</h2>
    <p class="max-w-2xl mx-auto mb-6">If you have any questions about volunteering with Genderbase, please don't hesitate to reach out to our Volunteer Coordinator.</p>
    <a href="mailto:volunteer@genderbase.org" class="text-secondary hover:underline">volunteer@genderbase.org</a>
  </div>
</div>
