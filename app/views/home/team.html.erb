<div class="container mx-auto px-4 py-12">
  <h1 class="text-3xl font-bold mb-8">Our Team</h1>

  <p class="text-xl mb-10 max-w-4xl">Genderbase is brought to you by a dedicated team of individuals who are passionate about gender education, inclusion, and supporting our community.</p>

  <!-- Core Team Section -->
  <div class="mb-16">
    <h2 class="text-2xl font-bold mb-6 border-b pb-2">Core Team</h2>
    <p class="mb-8">Our core team members handle the day-to-day operations of Genderbase and also operate as responders.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Team Member 1 -->
      <div class="bg-base-200 rounded-xl p-6 flex flex-col items-center text-center">
        <div class="w-32 h-32 rounded-full bg-primary/20 mb-4 flex items-center justify-center">
          <%= image_tag "team/dave-williams.jpg", class: "w-32 h-32 rounded-full" %>
        </div>
        <h3 class="text-xl font-bold mb-2"><a href="https://dave.io">Dave Williams</a></h3>
        <p class="text-sm text-base-content/70 mb-2">Founder (they/them)</p>
        <p class="mb-4">DevOps engineer, general-purpose nerd, and great big queer monstrosity.</p>
        <div class="mt-auto">
          <a href="mailto:dave@genderbase.com" class="">dave@genderbase.com</a>
        </div>
      </div>
    </div>

    <!-- Volunteer Responders Section -->
    <div class="pt-6 ermb-16">
      <h2 class="text-2xl font-bold mb-6 border-b pb-2">Volunteer Responders</h2>
      <p class="mb-8">Our volunteer responders provide answers to user questions and manage the knowledge base.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pb-6">
        <!-- Team Member 5 -->
        <div class="bg-base-200 rounded-xl p-6 flex flex-col items-center text-center">
          <div class="w-32 h-32 rounded-full bg-secondary/20 mb-4 flex items-center justify-center">
            <span class="text-4xl">??</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Maybe You</h3>
          <p class="text-sm text-base-content/70 mb-2">Responder (they/them)</p>
          <p class="mb-4">Could you be a responder? We're always looking for more people to join our team.</p>
          <div class="mt-auto">
            <%= link_to "Learn About Volunteering", "/volunteer", class: "btn btn-primary" %>
          </div>
        </div>
      </div>