  <div class="text-center">
    <div class="flex justify-center mb-4">
      <div class="bg-secondary/20 rounded-full p-4 inline-block">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0-1.104.896-2 2-2s2 .896 2 2-.896 2-2 2-2-.896-2-2zm0 0V7m0 8v-2m0 0c-4.418 0-8 1.79-8 4v2h16v-2c0-2.21-3.582-4-8-4z" />
        </svg>
      </div>
    </div>
    <h1 class="text-4xl font-extrabold text-secondary mb-2">Security Policy</h1>
    <p class="text-lg text-base-content/70 max-w-2xl mx-auto">Your security is our priority. Learn how we protect your data and our platform at Genderbase.</p>
