<p style="color: green"><%= notice %></p>

<% content_for :title, @knowledge.title %>

<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="mb-6 flex justify-between items-center">
    <div>
      <nav class="text-sm breadcrumbs">
        <ul>
          <li><%= link_to "Knowledge Base", knowledges_path %></li>
          <li><%= @knowledge.title %></li>
        </ul>
      </nav>
    </div>
    <% if responder_signed_in? %>
    <div>
      <div class="dropdown dropdown-end">
        <label tabindex="0" class="btn btn-sm btn-ghost">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
          </svg>
        </label>
        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
          <li><%= link_to "Edit Entry", edit_knowledge_path(@knowledge) %></li>
          <li><%= link_to "Delete Entry", @knowledge, data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this knowledge base entry?" } %></li>
        </ul>
      </div>
    </div>
    <% end %>
  </div>

  <div class="bg-base-100 shadow-lg rounded-lg border border-base-300 overflow-hidden mb-8">
    <div class="p-6">
      <div class="flex justify-between items-start mb-4">
        <h1 class="text-2xl font-bold"><%= @knowledge.title %></h1>
        <span class="badge badge-<%= @knowledge.category == 'general' ? 'neutral' : 'primary' %>"><%= @knowledge.category.titleize %></span>
      </div>

      <% if @knowledge.description.present? %>
      <div class="mb-6 text-base-content/80 italic border-l-4 pl-3 border-base-300">
        <%= @knowledge.description %>
      </div>
      <% end %>

      <div class="prose max-w-none">
        <%= render_markdown(@knowledge.body) %>
      </div>

      <div class="mt-6 text-sm text-base-content/70 flex items-center justify-between">
        <div>
          Created by: <%= @knowledge.responder.pseudonym %> • <%= time_ago_in_words(@knowledge.created_at) %> ago
        </div>

        <% if @knowledge.question %>
        <div>
          <span class="mr-2">Based on:</span>
          <%= link_to "Question ##{@knowledge.question.id}", question_path(@knowledge.question), class: "link link-hover" %>
        </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex justify-between">
    <%= link_to "Back to Knowledge Base", knowledges_path, class: "btn btn-outline" %>

    <% if responder_signed_in? %>
    <%= link_to "Edit Entry", edit_knowledge_path(@knowledge), class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if @related_knowledges.any? %>
  <div class="mt-12">
    <h2 class="text-xl font-bold mb-6">Related Entries</h2>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% @related_knowledges.each do |related| %>
      <%= render related %>
      <% end %>
    </div>
  </div>
  <% end %>
</div>