<div id="<%= dom_id knowledge %>" class="bg-base-100 shadow-md rounded-lg border border-base-300 overflow-hidden hover:shadow-lg transition-shadow duration-300">
  <div class="p-6">
    <div class="flex justify-between items-start mb-3">
      <h3 class="text-lg font-semibold"><%= link_to knowledge.title, knowledge_path(knowledge), class: "hover:text-primary" %></h3>
      <span class="badge badge-<%= knowledge.category == 'general' ? 'neutral' : 'primary' %> ml-2"><%= knowledge.category.titleize %></span>
    </div>

    <% if knowledge.description.present? %>
    <div class="text-base-content/80 text-sm mb-4 line-clamp-3">
      <%= knowledge.description %>
    </div>
    <% end %>

    <div class="flex justify-between items-center text-xs text-base-content/60 mt-auto">
      <span>By <%= knowledge.responder.pseudonym %></span>
      <span><%= time_ago_in_words(knowledge.created_at) %> ago</span>
    </div>
  </div>
</div>