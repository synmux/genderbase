<% content_for :title, "Edit Answer" %>

<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="mb-6">
    <nav class="text-sm breadcrumbs">
      <ul>
        <li><%= link_to "Answers", answers_path %></li>
        <li><%= link_to "Answer ##{@answer.id}", answer_path(@answer) %></li>
        <li>Edit</li>
      </ul>
    </nav>
  </div>

  <div class="bg-base-100 shadow-lg rounded-lg border border-base-300 overflow-hidden">
    <div class="p-6">
      <h1 class="text-2xl font-bold mb-6">Edit Answer</h1>

      <% if @answer.question && @answer.question.knowledge %>
      <div class="bg-warning/10 text-warning p-4 rounded-lg mb-6">
        <div class="flex items-start">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <div class="ml-3">
            <p class="text-sm font-medium">This answer has already been used to create a Knowledge Base article.</p>
            <p class="text-xs mt-1">
              Consider editing the Knowledge Base article directly instead, or update both for consistency.
              <%= link_to "Edit Knowledge Article", edit_knowledge_path(@answer.question.knowledge), class: "underline" %>
            </p>
          </div>
        </div>
      </div>
      <% end %>

      <%= render "form", answer: @answer %>
    </div>
  </div>
</div>