<p style="color: green"><%= notice %></p>

<% content_for :title, "Answered Questions" %>

<div class="container mx-auto px-4 py-8 mt-16">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-base-content">Answered Questions</h1>
    <p class="text-base-content/75 mt-2">Browse questions answered by our gender experts</p>
  </div>

  <div class="max-w-4xl mx-auto">
    <div class="bg-base-200 rounded-lg shadow-md p-4 mb-8">
      <input type="text" placeholder="Search answered questions..." class="w-full px-4 py-2 rounded-md bg-base-100 text-base-content border border-base-300 focus:outline-none focus:ring-2 focus:ring-accent">
    </div>

    <div class="space-y-6" id="answers">
      <% @answers.each do |answer| %>
      <div class="bg-base-100 rounded-lg shadow-md p-6">
        <div class="mb-4 border-b border-base-300 pb-4">
          <h2 class="text-xl font-bold text-base-content">
            <%= h(answer.question.title) %>
          </h2>
          <div class="mt-2 flex items-center text-sm text-base-content/60">
            <% if answer.question.anonymous? %>
            <span>Asked by: Anonymous</span>
            <% else %>
            <span>Asked by: <%= h(answer.question.email.split('@').first) %></span>
            <% end %>
            <span class="mx-2">•</span>
            <span><%= h(answer.question.created_at.strftime("%B %d, %Y")) %></span>
          </div>
        </div>
        <div class="prose prose-sm max-w-none text-base-content/90">
          <p><%= h(truncate(answer.question.body, length: 150)) %></p>
        </div>
        <div class="mt-6 bg-base-200 p-4 rounded-lg">
          <div class="flex items-center mb-3">
            <div class="avatar">
              <div class="w-10 h-10 rounded-full bg-accent flex items-center justify-center text-accent-content font-bold">
                <%= h(answer.responder&.name&.split(' ')&.map { |n| n[0] }&.join || "GB") %>
              </div>
            </div>
            <div class="ml-3">
              <h3 class="font-medium text-base-content"><%= h(answer.responder&.name || "Genderbase Expert") %></h3>
              <p class="text-xs text-base-content/60"><%= h(answer.created_at.strftime("%B %d, %Y")) %></p>
            </div>
          </div>
          <div class="prose prose-sm max-w-none text-base-content/90">
            <%= h(truncate(strip_tags(answer.to_html), length: 200)) %>
          </div>
          <div class="mt-3 text-right">
            <%= link_to "Read full answer", answer %>
          </div>
        </div>
      </div>
      <% end %>

      <% if @answers.empty? %>
      <div class="text-center py-12 bg-base-100 rounded-lg shadow-md">
        <div class="text-4xl text-base-content/30 mb-4">💬</div>
        <h3 class="text-xl text-base-content font-medium">No answers yet</h3>
        <p class="text-base-content/70 mt-2">Check back soon for expert responses</p>
      </div>
      <% end %>
    </div>

    <div class="mt-8 flex justify-between items-center">
      <div class="join">
        <button class="join-item btn btn-sm">«</button>
        <button class="join-item btn btn-sm btn-active">1</button>
        <button class="join-item btn btn-sm">2</button>
        <button class="join-item btn btn-sm">3</button>
        <button class="join-item btn btn-sm">»</button>
      </div>

      <% if responder_signed_in? %>
      <%= link_to "New Answer", new_answer_path, class: "btn btn-accent btn-sm" %>
      <% end %>
    </div>
  </div>
</div>