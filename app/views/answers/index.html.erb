<p style="color: green"><%= notice %></p>

<% content_for :title, "Answer Management" %>

<div class="container mx-auto px-4 pt-6 pb-16">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-bold">Answer Management</h1>
    <div>
      <%= link_to "New Answer", new_answer_path, class: "btn btn-primary" %>
    </div>
  </div>

  <div class="mb-6">
    <div class="stats shadow w-full">
      <div class="stat">
        <div class="stat-figure text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
          </svg>
        </div>
        <div class="stat-title">Total Answers</div>
        <div class="stat-value text-primary"><%= @answers.count %></div>
        <div class="stat-desc">Your contributions</div>
      </div>

      <div class="stat">
        <div class="stat-figure text-success">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="stat-title">Knowledge Articles</div>
        <div class="stat-value text-success"><%= @answers.select { |a| a.question&.knowledge.present? }.count %></div>
        <div class="stat-desc">Converted to KB</div>
      </div>

      <div class="stat">
        <div class="stat-figure text-warning">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="stat-title">Pending Conversion</div>
        <div class="stat-value text-warning"><%= @answers.select { |a| a.question&.status == 1 && a.question&.knowledge.nil? }.count %></div>
        <div class="stat-desc">Ready for KB</div>
      </div>
    </div>
  </div>

  <div class="overflow-x-auto bg-base-100 rounded-lg border border-base-300 shadow-md">
    <table class="table w-full">
      <thead>
        <tr>
          <th class="bg-base-200">Question</th>
          <th class="bg-base-200 hidden lg:table-cell">Answered</th>
          <th class="bg-base-200 hidden md:table-cell">Status</th>
          <th class="bg-base-200 w-32">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @answers.each do |answer| %>
        <tr class="hover:bg-base-200/50 <%= answer.question&.knowledge ? 'bg-success/5' : '' %>">
          <td>
            <div>
              <% if answer.question %>
              <%= link_to answer.question.title, answer_path(answer), class: "font-medium hover:text-primary" %>
              <% else %>
              <span class="text-base-content/50 italic">Question unavailable</span>
              <% end %>
              <div class="text-xs text-base-content/60 mt-1">
                <span><%= truncate(answer.body, length: 100) %></span>
              </div>
            </div>
          </td>
          <td class="hidden lg:table-cell text-base-content/70"><%= time_ago_in_words(answer.created_at) %> ago</td>
          <td class="hidden md:table-cell">
            <% if answer.question %>
            <% if answer.question.knowledge %>
            <div class="badge badge-success gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              KB Article
            </div>
            <% elsif answer.question.status == 1 %>
            <div class="badge badge-warning gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Ready for KB
            </div>
            <% else %>
            <div class="badge badge-ghost gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
              In Progress
            </div>
            <% end %>
            <% else %>
            <div class="badge badge-error gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              Orphaned
            </div>
            <% end %>
          </td>
          <td>
            <div class="flex space-x-1">
              <%= link_to answer_path(answer), class: "btn btn-xs btn-ghost btn-square tooltip", data: { tooltip: "View" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              <% end %>

              <%= link_to edit_answer_path(answer), class: "btn btn-xs btn-ghost btn-square tooltip", data: { tooltip: "Edit" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              <% end %>

              <% if answer.question && answer.question.closed? && !answer.question.knowledge %>
              <%= link_to convert_to_knowledge_question_path(answer.question), class: "btn btn-xs btn-accent btn-square tooltip", data: { tooltip: "Create KB Article" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              <% end %>
              <% elsif answer.question && answer.question.knowledge %>
              <%= link_to answer.question.knowledge, class: "btn btn-xs btn-success btn-square tooltip", data: { tooltip: "View KB Article" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <% end %>
              <% end %>
            </div>
          </td>
        </tr>
        <% end %>

        <% if @answers.empty? %>
        <tr>
          <td colspan="4" class="text-center py-8 text-base-content/70">
            No answers yet. <%= link_to "Create your first answer", new_answer_path, class: "text-primary hover:underline" %>.
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
