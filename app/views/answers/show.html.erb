<p style="color: green"><%= notice %></p>

<% content_for :title, "Answer Details" %>

<div class="container mx-auto px-4 py-8 mt-16">
  <div class="max-w-4xl mx-auto">
    <nav class="text-sm mb-6 text-base-content/70">
      <%= link_to "Answers", answers_path, class: "hover:text-accent" %> /
      <span class="text-base-content">Answer Details</span>
    </nav>

    <div class="bg-base-100 rounded-lg shadow-md overflow-hidden">
      <div class="p-6">
        <% if @answer.question %>
        <div class="mb-6 border-b border-base-300 pb-4">
          <h2 class="text-xl font-bold text-base-content mb-2">Question: <%= @answer.question.title %></h2>
          <div class="prose max-w-none text-base-content/90">
            <p><%= @answer.question.body %></p>
          </div>
          <div class="mt-4 text-sm text-base-content/60">
            <% if @answer.question.anonymous? %>
            <span>Asked by: Anonymous</span>
            <% else %>
            <span>Asked by: <%= @answer.question.email.split('@').first %></span>
            <% end %>
            <span class="mx-2">•</span>
            <span><%= @answer.question.created_at.strftime("%B %d, %Y") %></span>
          </div>
        </div>
        <% end %>

        <div class="mb-4">
          <h1 class="text-2xl font-bold text-base-content mb-2">Answer</h1>

          <% if @answer.responder %>
          <div class="flex items-center mb-4">
            <div class="avatar">
              <div class="w-12 h-12 rounded-full bg-accent flex items-center justify-center text-accent-content font-bold">
                <%= @answer.responder.name&.split(' ')&.map { |n| n[0] }&.join || "RES" %>
              </div>
            </div>
            <div class="ml-3">
              <p class="font-medium"><%= @answer.responder.name || @answer.responder.username %></p>
              <p class="text-sm text-base-content/60"><%= @answer.created_at.strftime("%B %d, %Y • %H:%M") %></p>
            </div>
          </div>
          <% end %>

          <div class="prose max-w-none text-base-content/90 border-t border-base-300 pt-4">
            <%= @answer.to_html %>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 flex justify-between">
      <%= link_to "← Back to answers", answers_path, class: "text-accent hover:underline" %>

      <% if responder_signed_in? %>
      <div class="space-x-2">
        <%= link_to "Edit", edit_answer_path(@answer), class: "btn btn-sm" %>
        <%= button_to "Delete", @answer, method: :delete, class: "btn btn-sm btn-error", form: { data: { turbo_confirm: "Are you sure you want to delete this answer?" } } %>
      </div>
      <% end %>
    </div>

    <% if @answer.question && !@answer.question.knowledge %>
    <div class="mt-8 p-4 rounded-lg bg-base-200">
      <h3 class="font-medium mb-2">Create an article from this question and answer?</h3>
      <p class="text-base-content/80 mb-4 text-sm">
        Creating an article allows you to provide a more comprehensive resource based on this answer.
      </p>
      <%= link_to "Create Article", new_knowledge_path(question_id: @answer.question.id), class: "btn btn-sm btn-accent" %>
    </div>
    <% end %>
  </div>
</div>
