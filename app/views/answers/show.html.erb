<p style="color: green"><%= notice %></p>

<% content_for :title, "Answer Details" %>

<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="mb-6">
    <nav class="text-sm breadcrumbs">
      <ul>
        <li><%= link_to "Answers", answers_path %></li>
        <li>Answer #<%= @answer.id %></li>
      </ul>
    </nav>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <div class="bg-base-100 rounded-lg shadow-lg border border-base-300 overflow-hidden mb-6">
        <% if @answer.question %>
        <div class="border-b border-base-300 p-6">
          <div class="flex justify-between items-start mb-4">
            <h2 class="text-xl font-bold text-base-content"><%= @answer.question.title %></h2>
            <% case @answer.question.status %>
            <% when 0 %>
            <span class="badge badge-warning">Pending</span>
            <% when 1 %>
            <span class="badge badge-success">Answered</span>
            <% when 2 %>
            <span class="badge badge-neutral">Archived</span>
            <% end %>
          </div>
          <div class="prose max-w-none text-base-content/90 mb-4">
            <%= simple_format(@answer.question.body) %>
          </div>
          <div class="text-sm text-base-content/60">
            Asked by: <%= @answer.question.pseudonym.presence || "Anonymous" %> •
            <%= time_ago_in_words(@answer.question.created_at) %> ago
          </div>
        </div>
        <% end %>

        <div class="p-6">
          <div class="flex items-center mb-4">
            <div class="avatar placeholder mr-3">
              <div class="bg-neutral-focus text-neutral-content rounded-full w-10">
                <span><%= @answer.responder.name.first.upcase %></span>
              </div>
            </div>
            <div>
              <div class="font-medium"><%= @answer.responder.name %></div>
              <div class="text-xs text-base-content/60"><%= time_ago_in_words(@answer.created_at) %> ago</div>
            </div>
          </div>

          <div class="prose max-w-none">
            <%= simple_format(@answer.body) %>
          </div>
        </div>
      </div>

      <div class="flex justify-between mb-6">
        <%= link_to "← Back to answers", answers_path, class: "text-primary hover:text-primary-focus" %>

        <div class="space-x-2">
          <%= link_to "Edit", edit_answer_path(@answer), class: "btn btn-sm" %>
          <%= button_to "Delete", @answer, method: :delete, class: "btn btn-sm btn-error", form: { data: { turbo_confirm: "Are you sure you want to delete this answer?" } } %>
        </div>
      </div>
    </div>

    <% if @answer.question && @answer.question.status == 1 && !@answer.question.knowledge %>
    <div class="bg-base-100 rounded-lg shadow-lg border border-base-300 p-6 h-fit sticky top-24">
      <h3 class="text-lg font-bold mb-4">Create Knowledge Base Article</h3>

      <div class="bg-info/10 text-info p-4 rounded-lg mb-4">
        <div class="flex">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="ml-2 text-sm">
            This question has been answered. Create a Knowledge Base article to make this information accessible to all users.
          </p>
        </div>
      </div>

      <%= form_with(model: Knowledge.new, url: knowledges_path, class: "space-y-4") do |form| %>
      <%= form.hidden_field :question_id, value: @answer.question.id %>
      <%= form.hidden_field :responder_id, value: current_responder.id %>

      <div class="form-control">
        <%= form.label :title, "Article Title", class: "label font-medium text-base-content" %>
        <div class="label-text-alt text-base-content/70">Choose a clear, descriptive title</div>
        <%= form.text_field :title, value: @answer.question.title, class: "input input-bordered w-full mt-1" %>
      </div>

      <div class="form-control">
        <%= form.label :description, "Summary", class: "label font-medium text-base-content" %>
        <div class="label-text-alt text-base-content/70">A brief description that will appear in search results</div>
        <%= form.text_area :description, rows: 2, class: "textarea textarea-bordered w-full mt-1" %>
      </div>

      <div class="form-control">
        <%= form.label :category, "Category", class: "label font-medium text-base-content" %>
        <%= form.select :category,
                           [["General", 0], ["Pronouns", 1], ["Identity", 2], ["Other", 3]],
                           {},
                           class: "select select-bordered w-full" %>
      </div>

      <div class="form-control">
        <%= form.label :body, "Article Content", class: "label font-medium text-base-content" %>
        <div class="label-text-alt text-base-content/70">Distill the question and answer into a comprehensive article</div>
        <%= form.text_area :body, value: @answer.body, rows: 10, class: "textarea textarea-bordered w-full mt-1" %>
      </div>

      <div class="mt-6">
        <%= form.submit "Create Knowledge Base Article", class: "btn btn-accent w-full" %>
      </div>
      <% end %>
    </div>
    <% elsif @answer.question && @answer.question.knowledge %>
    <div class="bg-base-100 rounded-lg shadow-lg border border-base-300 p-6 h-fit">
      <h3 class="text-lg font-bold mb-4">Knowledge Base Article</h3>
      <div class="bg-success/10 text-success p-4 rounded-lg mb-4">
        <div class="flex">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <p class="ml-2 text-sm">
            This question has been converted into a Knowledge Base article.
          </p>
        </div>
      </div>

      <div class="mt-4">
        <h4 class="font-medium"><%= @answer.question.knowledge.title %></h4>
        <p class="text-sm text-base-content/70 mt-1"><%= @answer.question.knowledge.description %></p>
      </div>

      <div class="mt-4">
        <%= link_to "View Article", @answer.question.knowledge, class: "btn btn-sm btn-outline w-full" %>
        <%= link_to "Edit Article", edit_knowledge_path(@answer.question.knowledge), class: "btn btn-sm btn-ghost w-full mt-2" %>
      </div>
    </div>
    <% elsif @answer.question && @answer.question.status != 1 %>
    <div class="bg-base-100 rounded-lg shadow-lg border border-base-300 p-6 h-fit">
      <h3 class="text-lg font-bold mb-4">Create Knowledge Base Article</h3>
      <div class="bg-warning/10 text-warning p-4 rounded-lg">
        <div class="flex">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <p class="ml-2 text-sm">
            Question must be marked as "Answered" before creating a Knowledge Base article.
          </p>
        </div>
      </div>

      <div class="mt-4">
        <%= link_to "Mark Question as Answered", question_path(@answer.question, question: { status: 1 }), data: { turbo_method: :patch }, class: "btn btn-sm btn-warning w-full" %>
      </div>
    </div>
    <% end %>
  </div>
</div>