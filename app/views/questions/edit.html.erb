<% content_for :title, "Edit Question" %>

<div class="container mx-auto px-4 py-8 max-w-3xl">
  <div class="mb-6">
    <nav class="text-sm breadcrumbs">
      <ul>
        <li><%= link_to "Questions", questions_path %></li>
        <li><%= link_to "Question ##{@question.id}", question_path(@question) %></li>
        <li>Edit</li>
      </ul>
    </nav>
  </div>

  <div class="bg-base-100 shadow-lg rounded-lg border border-base-300 p-6">
    <h1 class="text-2xl font-bold mb-6">Edit Question</h1>

    <%= render "form", question: @question %>

    <div class="mt-6 pt-6 border-t border-base-300 flex justify-between">
      <%= link_to "← Back to question", @question, class: "text-primary hover:text-primary-focus" %>

      <%= button_to "Delete Question", @question, method: :delete, class: "btn btn-sm btn-error", form: { data: { turbo_confirm: "Are you sure you want to delete this question?" } } %>
    </div>
  </div>
</div>
