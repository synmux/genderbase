<p style="color: green"><%= notice %></p>

<% content_for :title, "Question Management" %>

<div class="container mx-auto px-4 sm:px-6 md:px-8 pt-6 pb-16">
  <div class="flex flex-wrap justify-between items-center mb-8">
    <h1 class="text-2xl font-bold flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
      </svg>
      Conversation Management
    </h1>
  </div>

  <div class="bg-base-200 p-4 rounded-lg mb-6">
    <div class="flex flex-col md:flex-row justify-between gap-4">
      <div>
        <h2 class="text-base font-semibold mb-2 flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
          </svg>
          Filters
        </h2>
        <div class="flex flex-wrap gap-2">
          <button class="btn btn-sm status-filter active" data-status="all">
            <span class="badge badge-sm badge-ghost mr-1"><%= @questions.count %></span>All
          </button>
          <button class="btn btn-sm status-filter" data-status="0">
            <span class="badge badge-sm badge-warning mr-1"><%= @questions.where(status: 0).count %></span>Open
          </button>
          <button class="btn btn-sm status-filter" data-status="1">
            <span class="badge badge-sm badge-success mr-1"><%= @questions.where(status: 1).count %></span>Active
          </button>
          <button class="btn btn-sm status-filter" data-status="2">
            <span class="badge badge-sm badge-neutral mr-1"><%= @questions.where(status: 2).count %></span>Closed
          </button>
        </div>
      </div>
      <div>
        <h2 class="text-base font-semibold mb-2 flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Knowledge Base
        </h2>
        <div class="flex flex-wrap gap-2">
          <button class="btn btn-sm knowledge-filter" data-knowledge="with">
            <span class="badge badge-sm badge-success mr-1"><%= @questions.joins(:knowledge).count %></span>With KB Entry
          </button>
          <button class="btn btn-sm knowledge-filter" data-knowledge="without">
            <span class="badge badge-sm badge-warning mr-1"><%= @questions.where(status: 2).where.not(id: @questions.joins(:knowledge).pluck(:id)).count %></span>Ready for KB
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="w-full mb-4">
    <div class="relative">
      <input type="text" id="question-search" placeholder="Search conversations..." class="input input-bordered w-full pl-10" />
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 absolute left-3 top-3 text-base-content/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
    <% if @questions.any? %>
    <% @questions.each do |question| %>
    <div class="question-row card bg-base-100 border border-base-300 hover:shadow-md transition-shadow duration-200" data-status="<%= question.status_before_type_cast %>" data-has-knowledge="<%= question.knowledge ? 'true' : 'false' %>" data-title="<%= question.title.downcase %>" data-from="<%= question.pseudonym&.downcase || 'anonymous' %>">

      <div class="card-body p-4">
        <div class="flex justify-between items-start">
          <div class="flex gap-2 items-center">
            <div class="avatar placeholder">
              <div class="bg-primary text-primary-content rounded-full w-8">
                <span><%= question.pseudonym.present? ? question.pseudonym.first.upcase : "A" %></span>
              </div>
            </div>
            <div>
              <span class="text-sm text-base-content/70"><%= question.pseudonym.presence || "Anonymous" %></span>
              <div class="text-xs text-base-content/50"><%= time_ago_in_words(question.created_at) %> ago</div>
            </div>
          </div>

          <div class="flex items-center gap-1">
            <% case question.status %>
            <% when "open" %>
            <span class="badge badge-warning gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Open
            </span>
            <% when "active" %>
            <span class="badge badge-success gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Active
            </span>
            <% when "closed" %>
            <span class="badge badge-neutral gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Closed
            </span>
            <% end %>

            <div class="badge badge-ghost gap-1 ml-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
              <%= question.answers.count %>
            </div>
          </div>
        </div>

        <h2 class="card-title text-base mt-3">
          <%= link_to question.title, question_path(question), class: "hover:text-primary transition-colors duration-200 line-clamp-2" %>
        </h2>

        <div class="mt-1 text-sm text-base-content/70 line-clamp-2">
          <%= truncate(strip_tags(question.body), length: 100) %>
        </div>

        <div class="card-actions justify-between items-center mt-4 pt-3 border-t border-base-200">
          <div>
            <% if question.knowledge %>
            <div class="badge badge-success gap-1 py-2 px-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>KB Entry</span>
            </div>
            <% elsif question.closed? %>
            <div class="badge badge-warning gap-1 py-2 px-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              <span>Ready for KB</span>
            </div>
            <% else %>
            <div class="badge badge-ghost badge-sm py-2 px-3">Not Ready</div>
            <% end %>
          </div>

          <div class="flex gap-1">
            <%= link_to question_path(question), class: "btn btn-xs btn-ghost tooltip", data: { tooltip: "View" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <% end %>

            <%= link_to question_path(question), class: "btn btn-xs btn-primary tooltip", data: { tooltip: "Reply" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
            </svg>
            Reply
            <% end %>

            <div class="dropdown dropdown-end">
              <label tabindex="0" class="btn btn-xs btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                </svg>
              </label>
              <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
                <li><%= link_to "View Details", question_path(question) %></li>
                <% if !question.closed? %>
                <li>
                  <% if question.open? %>
                  <%= link_to "Mark as Active", question_path(question, question: { status: 'active' }), data: { turbo_method: :patch } %>
                  <% elsif question.active? %>
                  <%= link_to "Mark as Open", question_path(question, question: { status: 'open' }), data: { turbo_method: :patch } %>
                  <% end %>
                </li>
                <li><%= link_to "Close Conversation", close_question_path(question), data: { turbo_method: :post, turbo_confirm: "Are you sure you want to close this conversation?" } %></li>
                <% end %>
                <% if question.closed? && !question.knowledge %>
                <li><%= link_to "Create KB Article", convert_to_knowledge_question_path(question) %></li>
                <% elsif question.knowledge %>
                <li><%= link_to "View KB Article", question.knowledge %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% end %>
    <% else %>
    <div class="col-span-full flex flex-col items-center justify-center py-16 bg-base-100 rounded-lg border border-base-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-base-content/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
      </svg>
      <h3 class="mt-4 text-xl font-medium">No questions yet</h3>
      <p class="mt-2 text-base-content/60">When users submit questions, they will appear here for you to respond to.</p>
    </div>
    <% end %>
  </div>

  <% if @questions.count > 15 %>
  <div class="text-center mt-8">
    <button class="btn btn-ghost btn-sm gap-1 load-more">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
      Load More
    </button>
  </div>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const statusFilterButtons = document.querySelectorAll('.status-filter');
    const knowledgeFilterButtons = document.querySelectorAll('.knowledge-filter');
    const questionRows = document.querySelectorAll('.question-row');
    const searchInput = document.getElementById('question-search');
    let activeStatusFilter = 'all';
    let activeKnowledgeFilter = null;

    function applyFilters() {
      questionRows.forEach(row => {
        const status = row.getAttribute('data-status');
        const hasKnowledge = row.getAttribute('data-has-knowledge');
        const title = row.getAttribute('data-title');
        const from = row.getAttribute('data-from');
        const searchQuery = searchInput.value.toLowerCase();

        let showByStatus = activeStatusFilter === 'all' || status === activeStatusFilter;
        let showByKnowledge = true;
        let showBySearch = true;

        if (searchQuery) {
          showBySearch = title.includes(searchQuery) || from.includes(searchQuery);
        }

        if (activeKnowledgeFilter === 'with') {
          showByKnowledge = hasKnowledge === 'true';
        } else if (activeKnowledgeFilter === 'without') {
          showByKnowledge = hasKnowledge === 'false' && status === '2'; // Closed without KB
        }

        row.style.display = (showByStatus && showByKnowledge && showBySearch) ? '' : 'none';
      });
    }

    statusFilterButtons.forEach(button => {
      button.addEventListener('click', function() {
        // Remove active class from all status buttons
        statusFilterButtons.forEach(btn => btn.classList.remove('active', 'btn-active'));

        // Add active class to clicked button
        this.classList.add('active', 'btn-active');

        // Store the active filter
        activeStatusFilter = this.getAttribute('data-status');

        // Apply all filters
        applyFilters();
      });
    });

    knowledgeFilterButtons.forEach(button => {
      button.addEventListener('click', function() {
        if (this.classList.contains('active')) {
          // If already active, deactivate it
          this.classList.remove('active', 'btn-active');
          activeKnowledgeFilter = null;
        } else {
          // Remove active class from all knowledge buttons
          knowledgeFilterButtons.forEach(btn => btn.classList.remove('active', 'btn-active'));

          // Add active class to clicked button
          this.classList.add('active', 'btn-active');

          // Store the active filter
          activeKnowledgeFilter = this.getAttribute('data-knowledge');
        }

        // Apply all filters
        applyFilters();
      });
    });

    // Add search functionality
    searchInput.addEventListener('input', function() {
      applyFilters();
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
