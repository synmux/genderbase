<p style="color: green"><%= notice %></p>

<% content_for :title, @question.title %>

<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="mb-6 flex justify-between items-center">
    <div>
      <nav class="text-sm breadcrumbs">
        <ul>
          <li><%= link_to "Questions", questions_path %></li>
          <li>Question #<%= @question.id %></li>
        </ul>
      </nav>
    </div>
    <div>
      <% if responder_signed_in? %>
      <div class="dropdown dropdown-end">
        <label tabindex="0" class="btn btn-sm btn-ghost">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
          </svg>
        </label>
        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
          <li><%= link_to "Edit Question", edit_question_path(@question) %></li>
          <li>
            <% if @question.open? %>
            <%= link_to "Mark as Active", question_path(@question, question: { status: 'active' }), data: { turbo_method: :patch } %>
            <% elsif @question.active? %>
            <%= link_to "Mark as Open", question_path(@question, question: { status: 'open' }), data: { turbo_method: :patch } %>
            <% end %>
          </li>
          <li><%= link_to "Close Question", close_question_path(@question), data: { turbo_method: :post, turbo_confirm: "Are you sure you want to close this question? This will finalize the Q&A process." } %></li>
        </ul>
      </div>
      <% end %>
    </div>
  </div>

  <div class="bg-base-100 shadow-lg rounded-lg border border-base-300 overflow-hidden mb-8">
    <div class="p-6">
      <div class="flex flex-wrap justify-between items-start gap-2">
        <h1 class="text-2xl font-bold mb-4 flex-grow"><%= @question.title %></h1>
        <% case @question.status %>
        <% when "open" %>
        <span class="badge badge-warning badge-lg gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Open
        </span>
        <% when "active" %>
        <span class="badge badge-success badge-lg gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Active
        </span>
        <% when "closed" %>
        <span class="badge badge-neutral badge-lg gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Closed
        </span>
        <% end %>
      </div>

      <div class="mb-4 flex items-center gap-2 text-sm text-base-content/70">
        <div class="avatar placeholder">
          <div class="bg-primary text-primary-content rounded-full w-8">
            <span><%= @question.pseudonym.present? ? @question.pseudonym.first.upcase : "A" %></span>
          </div>
        </div>
        <span><%= @question.pseudonym.presence || "Anonymous" %> • <%= time_ago_in_words(@question.created_at) %> ago</span>
      </div>

      <div class="prose max-w-none bg-base-200/50 p-4 rounded-lg border border-base-300 mb-4">
        <%= render_markdown(@question.body) %>
      </div>

      <% if responder_signed_in? %>
      <div class="flex flex-wrap gap-2 mt-4">
        <% if !@question.closed? %>
        <% if @question.open? %>
        <%= link_to question_path(@question, question: { status: 'active' }), data: { turbo_method: :patch }, class: "btn btn-sm btn-success gap-1" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Mark as Active
        <% end %>
        <% else %>
        <%= link_to question_path(@question, question: { status: 'open' }), data: { turbo_method: :patch }, class: "btn btn-sm btn-warning gap-1" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Mark as Open
        <% end %>
        <% end %>
        <%= link_to close_question_path(@question), data: { turbo_method: :post, turbo_confirm: "Are you sure you want to close this question? This will finalize the Q&A process." }, class: "btn btn-sm btn-neutral gap-1" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Close Question
        <% end %>
        <% end %>
        <%= link_to edit_question_path(@question), class: "btn btn-sm btn-ghost gap-1" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        Edit
        <% end %>
      </div>
      <% end %>
    </div>
  </div>

  <% if @answers.any? %>
  <div class="flex items-center gap-2 mb-4">
    <h2 class="text-xl font-bold">Conversation</h2>
    <span class="badge badge-primary"><%= @answers.count %> <%= @answers.count == 1 ? 'message' : 'messages' %></span>
  </div>

  <div class="space-y-6 mb-8">
    <% @answers.each do |answer| %>
    <div class="bg-base-100 shadow rounded-lg border <%= answer.responder_id.present? ? 'border-accent/30' : 'border-primary/30' %> p-6">
      <div class="flex justify-between items-start mb-4">
        <div class="flex items-center">
          <% if answer.responder_id.present? %>
          <div class="avatar placeholder mr-3">
            <div class="bg-accent text-accent-content rounded-full w-10">
              <span><%= answer.responder.pseudonym.first.upcase rescue "R" %></span>
            </div>
          </div>
          <div>
            <div class="font-medium flex items-center gap-1">
              <%= answer.responder.pseudonym %>
              <span class="badge badge-accent badge-sm">Responder</span>
            </div>
            <div class="text-xs text-base-content/60"><%= time_ago_in_words(answer.created_at) %> ago</div>
          </div>
          <% else %>
          <div class="avatar placeholder mr-3">
            <div class="bg-primary text-primary-content rounded-full w-10">
              <span><%= @question.pseudonym.present? ? @question.pseudonym.first.upcase : "U" %></span>
            </div>
          </div>
          <div>
            <div class="font-medium flex items-center gap-1">
              <%= @question.pseudonym.presence || "User" %>
              <span class="badge badge-primary badge-sm">Inquirer</span>
            </div>
            <div class="text-xs text-base-content/60"><%= time_ago_in_words(answer.created_at) %> ago</div>
          </div>
          <% end %>
        </div>

        <% if responder_signed_in? && answer.responder_id.present? && current_responder.id == answer.responder_id %>
        <div class="dropdown dropdown-end">
          <label tabindex="0" class="btn btn-xs btn-ghost">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
            </svg>
          </label>
          <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
            <li><%= link_to "Edit Message", edit_answer_path(answer) %></li>
            <li><%= link_to "Delete Message", answer_path(answer), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %></li>
          </ul>
        </div>
        <% end %>
      </div>

      <div class="prose max-w-none bg-base-200/30 p-4 rounded-lg">
        <%= render_markdown(answer.body) %>
      </div>
    </div>
    <% end %>
  </div>
  <% else %>
  <div class="bg-base-100 shadow rounded-lg border border-base-300 p-8 text-center mb-8">
    <div class="flex flex-col items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
      </svg>
      <p class="text-base-content/70 text-lg">No messages yet in this conversation.</p>
      <% if responder_signed_in? && !@question.closed? %>
      <p class="text-base-content/50">Reply to this question to start the conversation.</p>
      <% end %>
    </div>
  </div>
  <% end %>

  <% if responder_signed_in? && !@question.closed? %>
  <div class="bg-base-100 shadow-lg rounded-lg border border-accent/30 overflow-hidden animate__animated animate__fadeIn">
    <div class="p-6">
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
        </svg>
        Reply to Question
      </h2>

      <%= form_with(model: @new_answer, class: "space-y-4") do |form| %>
      <%= form.hidden_field :question_id, value: @question.id %>

      <div class="form-control w-full">
        <%= form.label :body, "Your Response", class: "label font-medium text-base-content" %>
        <div class="label-text-alt text-base-content/70 mb-2">
          You can use Markdown for formatting your response.
          <a href="#" class="text-accent" onclick="document.getElementById('markdown-help').classList.toggle('hidden'); return false;">Show formatting help</a>
        </div>
        <%= form.text_area :body, rows: 8, class: "textarea textarea-bordered w-full bg-base-100 text-base-content border border-base-300 rounded-md", placeholder: "Write your response here..." %>

        <div id="markdown-help" class="hidden mt-2 p-3 bg-base-200 rounded-md text-sm">
          <p class="font-semibold mb-1">Markdown Formatting Guide:</p>
          <ul class="list-disc ml-5 text-xs space-y-1">
            <li><code>**bold text**</code> for <strong>bold text</strong></li>
            <li><code>*italic text*</code> for <em>italic text</em></li>
            <li><code>## Heading</code> for section headings</li>
            <li><code>- item</code> for bullet lists</li>
            <li><code>1. item</code> for numbered lists</li>
            <li><code>[link text](https://example.com)</code> for links</li>
          </ul>
        </div>
      </div>

      <div class="bg-accent/10 p-4 rounded-lg mt-4">
        <h3 class="font-medium text-accent mb-2 flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Tips for Effective Responses
        </h3>
        <ul class="space-y-2 text-sm text-base-content/80">
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Use clear, accessible language that avoids unnecessarily complex terminology</span>
          </li>
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Structure your answer with logical sections to make it easy to follow</span>
          </li>
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Include reliable information sources where appropriate</span>
          </li>
        </ul>
      </div>

      <div class="mt-6 pt-4 border-t border-base-300">
        <%= form.submit "Submit Response", class: "btn btn-accent" %>
      </div>
      <% end %>
    </div>
  </div>
  <% elsif !@question.closed? && params[:token].present? %>
  <div class="bg-base-100 shadow-lg rounded-lg border border-primary/30 overflow-hidden animate__animated animate__fadeIn">
    <div class="p-6">
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
        Continue the Conversation
      </h2>

      <%= form_with(model: @new_answer, class: "space-y-4") do |form| %>
      <%= form.hidden_field :question_id, value: @question.id %>
      <%= hidden_field_tag :token, params[:token] %>

      <div class="form-control w-full">
        <%= form.label :body, "Your Message", class: "label font-medium text-base-content" %>
        <div class="label-text-alt text-base-content/70 mb-2">
          You can use Markdown for formatting your message.
          <a href="#" class="text-primary" onclick="document.getElementById('user-markdown-help').classList.toggle('hidden'); return false;">Show formatting help</a>
        </div>
        <%= form.text_area :body, rows: 6, class: "textarea textarea-bordered w-full bg-base-100 text-base-content border border-base-300 rounded-md", placeholder: "Write your message here..." %>

        <div id="user-markdown-help" class="hidden mt-2 p-3 bg-base-200 rounded-md text-sm">
          <p class="font-semibold mb-1">Markdown Formatting Guide:</p>
          <ul class="list-disc ml-5 text-xs space-y-1">
            <li><code>**bold text**</code> for <strong>bold text</strong></li>
            <li><code>*italic text*</code> for <em>italic text</em></li>
            <li><code>## Heading</code> for section headings</li>
            <li><code>- item</code> for bullet lists</li>
            <li><code>1. item</code> for numbered lists</li>
            <li><code>[link text](https://example.com)</code> for links</li>
          </ul>
        </div>
      </div>

      <div class="mt-6 pt-4 border-t border-base-300">
        <%= form.submit "Send Message", class: "btn btn-primary" %>
      </div>
      <% end %>
    </div>
  </div>
  <% elsif @question.closed? %>
  <div class="alert alert-info shadow-lg">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    <div>
      <h3 class="font-bold">Conversation Closed</h3>
      <div class="text-xs">This conversation has been closed. No more messages can be added.</div>
    </div>
  </div>
  <% end %>

  <% if @knowledge %>
  <div class="mt-8">
    <div class="flex items-center gap-2 mb-4">
      <h2 class="text-xl font-bold flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Knowledge Base Entry
      </h2>
      <span class="badge badge-success">Published</span>
    </div>
    <div class="bg-base-100 shadow-lg rounded-lg border border-success/30 overflow-hidden hover:shadow-xl transition-shadow duration-300">
      <div class="p-6">
        <h3 class="text-xl font-semibold mb-2"><%= link_to @knowledge.title, knowledge_path(@knowledge), class: "link link-hover text-success" %></h3>
        <p class="text-base-content/80 mb-4"><%= @knowledge.description %></p>
        <%= link_to "View Full Article", knowledge_path(@knowledge), class: "btn btn-sm btn-success gap-1" %>
      </div>
    </div>
  </div>
  <% elsif responder_signed_in? && @question.closed? %>
  <div class="mt-8 p-6 bg-base-100 shadow-lg rounded-lg border border-success/30 text-center">
    <div class="flex flex-col items-center gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <h3 class="text-lg font-semibold">Create Knowledge Base Entry</h3>
      <p class="text-base-content/70 max-w-md mx-auto">This conversation is now closed and can be converted into a knowledge base article to help others with similar questions.</p>
      <%= link_to convert_to_knowledge_question_path(@question), class: "btn btn-success mt-2 gap-1" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
      </svg>
      Create KB Article
      <% end %>
    </div>
  </div>
  <% end %>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
