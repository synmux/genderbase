{
  "name": "genderbase-static",
  "version": "1.0.0",
  "description": "Static HTML/CSS/Stimulus version of Genderbase",
  "main": "index.html",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/tailwind.css -o ./public/css/tailwind.css",
    "watch:css": "tailwindcss -i ./assets/css/tailwind.css -o ./public/css/tailwind.css --watch",
    "build": "npm run build:css",
    "start": "npx serve ."
  },
  "keywords": [
    "gender",
    "education",
    "static",
    "html",
    "stimulus"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "stimulus": "^3.2.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "serve": "^14.2.1"
  }
}
