<% content_for :title, "Edit Knowledge Entry" %>

<div class="container mx-auto px-4 py-8 mt-16">
  <div class="max-w-4xl mx-auto">
    <nav class="text-sm mb-6 text-base-content/70">
      <%= link_to "Knowledge", articles_path, class: "hover:text-accent" %> /
      <%= link_to @article.title, @article, class: "hover:text-accent" %> /
      <span class="text-base-content">Edit</span>
    </nav>

    <div class="bg-base-100 rounded-lg shadow-md overflow-hidden">
      <div class="p-6">
        <h1 class="text-2xl font-bold text-base-content mb-6">Edit Knowledge Entry</h1>
        <%= render "form", article: @article %>
      </div>
    </div>
  </div>
</div>