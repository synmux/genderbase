<p style="color: green"><%= notice %></p>

<% content_for :title, "Knowledge Base" %>

<div class="container mx-auto px-4 py-8 mt-16">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-base-content">Knowledge Base</h1>
    <p class="text-base-content/75 mt-2">In-depth resources from our gender experts</p>
  </div>

  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between gap-4 mb-8">
      <div class="md:w-2/3">
        <div class="bg-base-200 rounded-lg shadow-md p-4">
          <%= form_with(url: articles_path, method: :get, data: { controller: "search-form" }) do |form| %>
          <div class="relative w-full">
            <%= form.text_field :query, value: params[:query], placeholder: "Find knowledge...", class: "w-full rounded-full border border-neutral-200 px-4 py-2 pl-10 text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent dark:border-neutral-600 dark:bg-neutral-800 dark:placeholder-neutral-400", data: { action: "input->search-form#submit" } %>
          </div>
          <% end %>
        </div>
      </div>
      <div class="md:w-1/3 flex gap-2">
        <select class="flex-grow px-4 py-2 rounded-md bg-base-200 text-base-content border border-base-300 focus:outline-none focus:ring-2 focus:ring-accent">
          <option value="">All Categories</option>
          <option value="education">Education</option>
          <option value="support">Support</option>
          <option value="resources">Resources</option>
        </select>
        <% if responder_signed_in? %>
        <%= link_to "New Entry", new_article_path, class: "btn btn-accent" %>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="articles">
      <% @articles.each do |article| %>
      <div class="bg-base-100 rounded-lg shadow-md overflow-hidden h-full flex flex-col">
        <div class="p-6 flex-grow">
          <div class="flex items-center gap-2 mb-3">
            <span class="px-3 py-1 bg-primary/20 text-primary rounded-full text-sm font-medium"><%= article.category %></span>
          </div>
          <h2 class="text-xl font-bold text-base-content mb-3"><%= article.title %></h2>
          <div class="prose prose-sm max-w-none text-base-content/80 mb-4">
            <%= article.description %>
          </div>
          <div class="mt-4 text-sm text-base-content/60">
            <span>By: <%= article.author || "Genderbase Team" %></span>
          </div>
        </div>
        <div class="border-t border-base-300 p-4 bg-base-100">
          <%= link_to "Read article", article, class: "text-accent hover:text-accent-focus transition-colors" %>
        </div>
      </div>
      <% end %>
    </div>

    <% if @articles.empty? %>
    <div class="text-center py-12">
      <div class="text-4xl text-base-content/30 mb-4">📚</div>
      <h3 class="text-xl text-base-content font-medium">No knowledge entries yet</h3>
      <p class="text-base-content/70 mt-2">Check back soon for more resources</p>
    </div>
    <% end %>

    <div class="mt-8 flex justify-center">
      <div class="join">
        <button class="join-item btn btn-sm">«</button>
        <button class="join-item btn btn-sm btn-active">1</button>
        <button class="join-item btn btn-sm">2</button>
        <button class="join-item btn btn-sm">3</button>
        <button class="join-item btn btn-sm">»</button>
      </div>
    </div>
  </div>
</div>