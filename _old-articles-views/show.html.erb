<p style="color: green"><%= notice %></p>

<% content_for :title, @article.title + " | Knowledge" %>

<div class="container mx-auto px-4 py-8 mt-16">
  <div class="max-w-4xl mx-auto">
    <nav class="text-sm mb-6 text-base-content/70">
      <%= link_to "Knowledge", articles_path, class: "hover:text-accent" %> /
      <span class="text-base-content"><%= @article.title %></span>
    </nav>

    <div class="bg-base-100 rounded-lg shadow-md overflow-hidden">
      <div class="p-6">
        <div class="flex flex-wrap justify-between items-start mb-6">
          <h1 class="text-3xl font-bold text-base-content"><%= @article.title %></h1>
          <span class="px-3 py-1 bg-primary/20 text-primary rounded-full text-sm font-medium mt-2 sm:mt-0"><%= @article.category %></span>
        </div>

        <% if @article.description.present? %>
        <div class="mb-6 text-lg text-base-content/80 italic border-l-4 border-accent/30 pl-4">
          <%= @article.description %>
        </div>
        <% end %>

        <div class="flex items-center mb-8 pb-4 border-b border-base-300">
          <div class="avatar">
            <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold">
              <%= @article.author&.split(' ')&.map { |n| n[0] }&.join || "GB" %>
            </div>
          </div>
          <div class="ml-3">
            <p class="font-medium"><%= @article.author || "Genderbase Team" %></p>
            <p class="text-sm text-base-content/60">
              Published: <%= @article.created_at.strftime("%B %d, %Y") %>
              <% if @article.updated_at > @article.created_at %>
              • Updated: <%= @article.updated_at.strftime("%B %d, %Y") %>
              <% end %>
            </p>
          </div>
        </div>

        <div class="prose prose-lg max-w-none text-base-content/90">
          <%= @article.to_html %>
        </div>
      </div>
    </div>

    <div class="mt-6 flex justify-between">
      <%= link_to "← Back to Knowledge", articles_path, class: "text-accent hover:underline" %>

      <% if responder_signed_in? %>
      <div class="space-x-2">
        <%= link_to "Edit", edit_article_path(@article), class: "btn btn-sm" %>
        <%= button_to "Delete", @article, method: :delete, class: "btn btn-sm btn-error", form: { data: { turbo_confirm: "Are you sure you want to delete this article?" } } %>
      </div>
      <% end %>
    </div>

    <% if @article.question.present? %>
    <div class="mt-8 bg-base-200 p-6 rounded-lg">
      <h2 class="text-xl font-bold mb-4">Related Question</h2>
      <div class="bg-base-100 rounded-lg p-4">
        <h3 class="font-medium text-lg"><%= @article.question.title %></h3>
        <p class="text-base-content/80 mt-2"><%= truncate(@article.question.content, length: 150) %></p>
        <%= link_to "View question", @article.question, class: "text-accent hover:underline mt-2 inline-block" %>
      </div>
    </div>
    <% end %>
  </div>
</div>