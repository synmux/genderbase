  },
  "engines": {
    "node": "~23.11.0"
  },
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/daveio/genderbase/blob/main/LICENSE"
    }
  ],
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.13",
    "@tailwindcss/cli": "^4.1.1",
    "tailwindcss": "^4.1.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.2"
  },
  "name": "genderbase",
  "packageManager": "pnpm@10.7.1",
  "private": true,
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:css",
    "build:js": "pnpx esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:css": "pnpx @tailwindcss/cli -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify"
  },
  "type": "module"
}
