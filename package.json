{
  "name": "genderbase",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Dave Williams",
    "email": "dave@dave.io",
    "url": "https://github.com/daveio"
  },
  "scripts": {
    "build": "bun run build:js && bun run build:css",
    "build:css": "bun run postcss ./app/assets/stylesheets/application.postcss.css -o ./app/assets/builds/application.css",
    "build:js": "bun run esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets"
  },
  "dependencies": {
    "@biomejs/biome": "^2.1.2",
    "@fontsource-variable/sora": "^5.2.6",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.16",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "daisyui": "^5.0.47",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^13.0.2",
    "stylelint": "^16.22.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-recommended": "^17.0.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.32.0",
    "@eslint/json": "^0.13.1",
    "@eslint/markdown": "^7.1.0",
    "esbuild": "^0.25.8",
    "eslint": "^9.32.0",
    "globals": "^16.3.0"
  },
  "packageManager": "bun@1.2.17",
  "engines": {
    "bun": "1.2.17",
    "node": "22.17.0"
  },
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/daveio/genderbase/blob/main/LICENSE"
    }
  ],
  "trustedDependencies": ["@biomejs/biome", "@tailwindcss/oxide", "esbuild"]
}
