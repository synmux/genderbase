  "dependencies": {
    "@fontsource-variable/sora": "^5.2.5",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.13",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.4",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "daisyui": "^5.0.26",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.1",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "esbuild": "^0.25.2"
  },
  "engines": {
    "node": "~23.11.0"
  },
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/daveio/genderbase/blob/main/LICENSE"
    }
  ],
  "name": "genderbase",
  "packageManager": "pnpm@10.8.1",
  "private": true,
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:css",
    "build:css": "pnpm dlx postcss-cli ./app/assets/stylesheets/application.postcss.css -o ./app/assets/builds/application.css",
    "build:js": "pnpm dlx esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets"
  }
}
